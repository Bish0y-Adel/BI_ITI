  <MdxScripts>
    <MdxScript dwd:design-time-name="756a051f-cc03-4438-af7d-be86aef7bc29">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Unite Price]
 AS [Qty Total Price]/ [Qty], 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
      <CalculationProperties>
        <CalculationProperty dwd:design-time-name="5a12bfbe-c3ac-407f-9648-0c96c4af0125">
          <CalculationReference>[Measures].[Sales Unite Price]</CalculationReference>
          <CalculationType>Member</CalculationType>
          <Translations>
            <Translation dwd:design-time-name="85854d05-a57a-4da8-89ec-290049bfdffc">
              <Language>3073</Language>
              <Caption>سعر الوحدة</Caption>
            </Translation>
          </Translations>
        </CalculationProperty>
      </CalculationProperties>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="c0b3ceb7-9473-46fa-983f-c2bdacf3efd1">
      <ID>KPI</ID>
      <Name>Qty KPI</Name>
      <Translations>
        <Translation dwd:design-time-name="7d01f0e6-daca-4fcd-a415-a39f3b7c6a41">
          <Language>3073</Language>
          <Caption>مؤشر الكمية</Caption>
        </Translation>
      </Translations>
      <Value>[Measures].[Qty]</Value>
      <Goal>1000</Goal>
      <Status>case
    when kpivalue("Qty KPI")&gt;1000 then 1
    when kpivalue("Qty KPI")&lt;1000 then -1
    else 0
end</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Traffic Light</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>