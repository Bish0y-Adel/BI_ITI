  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>StuGrade</DataSourceName>
        <CommandText>SELECT Student.St_Fname, Course.Crs_Name, Stud_Course.Grade
FROM     Course INNER JOIN
                  Stud_Course ON Course.Crs_Id = Stud_Course.Crs_Id INNER JOIN
                  Student ON Stud_Course.St_Id = Student.St_Id</CommandText>
      </Query>
      <Fields>
        <Field Name="St_Fname">
          <DataField>St_Fname</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Crs_Name">
          <DataField>Crs_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Grade">
          <DataField>Grade</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
